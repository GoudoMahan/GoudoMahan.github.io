# Giscus 评论系统配置
# 获取配置: https://giscus.app/zh-CN

# 1. 仓库: 格式为 "用户名/仓库名"
#    确保仓库是公开的，并且已安装 Giscus App
GISCUS_REPO=用户名/仓库名

# 2. 仓库 ID: 在 giscus.app 页面输入仓库后自动生成
GISCUS_REPO_ID=你的仓库ID

# 3. Discussion 分类: 建议使用 Announcements
GISCUS_CATEGORY=Announcements

# 4. 分类 ID: 在 giscus.app 页面选择分类后自动生成
GISCUS_CATEGORY_ID=你的分类ID

# ===================== 配置步骤 =====================
# 1. 打开 https://giscus.app/zh-CN
# 2. 在"仓库"中输入你的仓库地址
# 3. 在 GitHub 仓库 Settings -> Features 中启用 Discussions
# 4. 安装 Giscus App: https://github.com/apps/giscus
# 5. 复制页面下方生成的 data-repo-id 和 data-category-id 填入上方
