---
import { Icon } from "astro-icon/components";
import MainCard from "@/components/MainCard.astro";
import FeatureCard from "@/components/mdx/FeatureCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import LinkCard from "@/components/mdx/LinkCard.astro";
---

<BaseLayout title="首页">
  <MainCard
    title="Welcome to Mo_Han136"
    description=""
    image="/home.jpg"
    infoIcon="lucide:info"
  >
    <div class="space-y-8">
      <section class="py-6">
        <div class="flex flex-col items-center text-center">
          <h1
            class="text-4xl font-bold mb-4 bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent leading-loose"
          >
            你好，我是Mo_Han136
          </h1>
          <p class="text-xl text-base-content/80 max-w-3xl mb-8">
            上海交通大学 - 机械与动力工程学院 - 机械工程专业 - 23级本科生在读
            <br />
          </p>
          <div class="flex flex-wrap gap-4 justify-center">
            <a href="/about" class="btn btn-primary gap-2 btn-shine-effect">
              <Icon name="lucide:user" class="w-5 h-5" />
              <span>关于</span>
            </a>
            <a href="/project" class="btn btn-outline gap-2">
              <Icon name="lucide:folder" class="w-5 h-5" />
              <span>作品</span>
            </a>
            <a href="https://github.com/GoudoMahan" target="_blank" class="btn btn-outline gap-2">
              <Icon name="ri:github-line" class="w-5 h-5" />
              <span>GitHub</span>
            </a>
            <a href="https://space.bilibili.com/" target="_blank" class="btn btn-outline gap-2">
              <Icon name="ri:bilibili-line" class="w-5 h-5" />
              <span>Bilibili</span>
            </a>
          </div>
        </div>
      </section>

      <section class="py-6">
        <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
          <Icon name="lucide:sparkles" class="w-6 h-6 text-primary" />
          <span>常用链接</span>
        </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <LinkCard
              title="Bilibili Space"
              desc="我的Bilibili空间"
              url="https://space.bilibili.com/475480857"
              img="/bilibili.jpg"
              categories={["Bilibili", "Homepage", "Share"]}
            />
            <LinkCard
              title="Github Space"
              desc="我的Github空间"
              url="https://github.com/GoudoMahan"
              img="/public/profile.png"
              categories={["Github", "Homepage", "Share"]}
            />
            <LinkCard
              title="F1"
              desc="formula1"
              url="https://www.formula1.com/"
              img="/public/f1.png"
              categories={["F1", "Interest"]}
            />
            <LinkCard
              title="马莎F1"
              desc="主播主播，什么是undercut什么是overcut？"
              url="https://msf1.cn/"
              img="/public/msf1.jpg"
              categories={["F1", "Interest", "Share"]}
            />
            <!-- <LinkCard
              title="Tailwind CSS Documentation"              //卡片标题
              desc="Tailwind CSS 官方文档，适合保留为常用参考。"   //卡片描述文本
              url="https://tailwindcss.com/docs"              //卡片链接
              img                                             //左侧显示的图片地址
              icon="simple-icons:tailwindcss"                 //无图片时显示的图标

              categories={["Docs", "CSS", "Reference"]}        //卡片分类
            /> -->
          </div>
    
      </section>
    </div>
  </MainCard>
</BaseLayout>
