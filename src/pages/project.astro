---
import { Icon } from "astro-icon/components";
import MainCard from "@/components/MainCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="作品">
  <MainCard
    title="作品"
    description=""
    image="/project.jpg"
    infoIcon="lucide:code-2"
  >
    <section class="py-4">
      <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
        <Icon name="lucide:star" class="w-6 h-6 text-primary" />
        <span>代表作品待补充</span>
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {
          [
            {
              name: "项目一待补充",
              desc: "这里可以写项目用途、技术栈、解决的问题和你的职责。",
            },
            {
              name: "项目二待补充",
              desc: "这里可以写另一个作品，也可以是课程作业或个人练习。",
            },
            {
              name: "项目三待补充",
              desc: "如果暂时没有项目，可以先用这块作为后续预留位置。",
            },
            {
              name: "项目四待补充",
              desc: "你也可以在这里放网站、应用、脚本或设计作品。",
            },
          ].map((project) => (
            <div class="card bg-base-200 p-6">
              <h3 class="text-xl font-bold mb-2">{project.name}</h3>
              <p class="text-base-content/80">{project.desc}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- <section class="py-4">
